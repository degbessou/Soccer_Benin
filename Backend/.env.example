# Supabase Postgres connection string (use the connection pooler URI from the
# Supabase dashboard: Project Settings > Database > Connection string > URI).
# IMPORTANT: URL-encode special characters in the password (e.g. @ -> %40).
SUPABASE_DB_URL=postgresql+psycopg2://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173
